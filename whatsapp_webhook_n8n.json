    {
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "options": { "caseSensitive": false, "leftValue": "", "typeValidation": "strict" },
                "combinator": "and",
                "conditions": [
                  {
                    "leftValue": "={{ $json.body.message.messageStubType }}",
                    "rightValue": "REVOKE",
                    "operator": { "type": "string", "operation": "equals" }
                  }
                ]
              },
              "renameOutput": true,
              "outputKey": "ignorar"
            },
            {
              "conditions": {
                "options": { "caseSensitive": false },
                "combinator": "and",
                "conditions": [
                  {
                    "leftValue": "={{ $json.body.message.message.conversation !== undefined || $json.body.message.message.extendedTextMessage !== undefined }}",
                    "rightValue": "true",
                    "operator": { "type": "string", "operation": "equals" }
                  }
                ]
              },
              "renameOutput": true,
              "outputKey": "texto"
            },
            {
              "conditions": {
                "options": { "caseSensitive": false },
                "combinator": "and",
                "conditions": [
                  {
                    "leftValue": "={{ $json.body.message.message.audioMessage !== undefined || $json.body.message.message.pttMessage !== undefined }}",
                    "rightValue": "true",
                    "operator": { "type": "string", "operation": "equals" }
                  }
                ]
              },
              "renameOutput": true,
              "outputKey": "audio"
            },
            {
              "conditions": {
                "options": { "caseSensitive": false },
                "combinator": "and",
                "conditions": [
                  {
                    "leftValue": "={{ $json.body.message.message.imageMessage !== undefined || $json.body.message.message.documentMessage !== undefined }}",
                    "rightValue": "true",
                    "operator": { "type": "string", "operation": "equals" }
                  }
                ]
              },
              "renameOutput": true,
              "outputKey": "midia"
            }
          ]
        },
        "options": {}
      },
      "id": "node_switch_type",
      "name": "Switch — Tipo de Mensagem",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [680, 400]
    },
    {
      "parameters": {
        "jsCode": "// Extrai campos essenciais de mensagens de texto (Evolution API v2)\nconst body = $input.item.json.body;\nconst msg = body.message;\n\nconst from = msg.key?.remoteJid ?? '';\nconst pushName = msg.pushName ?? 'Paciente';\nconst timestamp = msg.messageTimestamp ?? Date.now();\n\nlet text = '';\nif (msg.message?.conversation) {\n  text = msg.message.conversation;\n} else if (msg.message?.extendedTextMessage?.text) {\n  text = msg.message.extendedTextMessage.text;\n}\n\nreturn [\n  {\n    json: {\n      from,\n      pushName,\n      timestamp,\n      messageType: 'text',\n      content: text,\n      rawMessage: msg\n    }\n  }\n];"
      },
      "id": "node_parse_text",
      "name": "Parse — Extrair Texto",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [920, 240]
    },
    {
      "parameters": {
        "jsCode": "// Extrai metadados do áudio e a URL de download (Evolution API v2)\nconst body = $input.item.json.body;\nconst msg = body.message;\n\nconst from = msg.key?.remoteJid ?? '';\nconst pushName = msg.pushName ?? 'Paciente';\nconst timestamp = msg.messageTimestamp ?? Date.now();\n\nconst audioMsg = msg.message?.audioMessage ?? msg.message?.pttMessage ?? {};\nconst mediaUrl = audioMsg.url ?? '';\nconst mimetype = audioMsg.mimetype ?? 'audio/ogg; codecs=opus';\nconst fileLength = audioMsg.fileLength ?? 0;\nconst seconds = audioMsg.seconds ?? 0;\n\nreturn [\n  {\n    json: {\n      from,\n      pushName,\n      timestamp,\n      messageType: 'audio',\n      mediaUrl,\n      mimetype,\n      fileLength,\n      durationSeconds: seconds,\n      rawMessage: msg\n    }\n  }\n];"
      },
      "id": "node_parse_audio",
      "name": "Parse — Extrair Áudio",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [920, 400]
    },
    {
      "parameters": {
        "jsCode": "// Extrai metadados de imagem ou documento PDF (Evolution API v2)\nconst body = $input.item.json.body;\nconst msg = body.message;\n\nconst from = msg.key?.remoteJid ?? '';\nconst pushName = msg.pushName ?? 'Paciente';\nconst timestamp = msg.messageTimestamp ?? Date.now();\n\nconst imageMsg = msg.message?.imageMessage;\nconst docMsg = msg.message?.documentMessage;\n\nlet mediaUrl = '';\nlet mimetype = '';\nlet caption = '';\nlet mediaType = 'image';\n\nif (imageMsg) {\n  mediaUrl = imageMsg.url ?? '';\n  mimetype = imageMsg.mimetype ?? 'image/jpeg';\n  caption = imageMsg.caption ?? '';\n  mediaType = 'image';\n} else if (docMsg) {\n  mediaUrl = docMsg.url ?? '';\n  mimetype = docMsg.mimetype ?? 'application/pdf';\n  caption = docMsg.caption ?? docMsg.fileName ?? '';\n  mediaType = 'document';\n}\n\nreturn [\n  {\n    json: {\n      from,\n      pushName,\n      timestamp,\n      messageType: mediaType,\n      mediaUrl,\n      mimetype,\n      caption,\n      rawMessage: msg\n    }\n  }\n];"
      },
      "id": "node_parse_media",
      "name": "Parse — Extrair Mídia",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [920, 560]
    },
