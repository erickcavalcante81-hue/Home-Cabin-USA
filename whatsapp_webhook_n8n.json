        "bodyParameters": {
          "parameters": [
            {
              "name": "body",
              "value": "={\n  \"model\": \"gpt-4o\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"Você é Dr. João Holanda, especialista em oncologia metabólica e nutrição. Analise a imagem ou PDF enviado pelo Sr. Edilson (76 anos, pós-câncer de próstata, Parintins-AM). Se for um exame laboratorial, extraia: PSA, eTFG, creatinina, hemograma completo e quaisquer marcadores relevantes. Se for foto de refeição, avalie o conteúdo nutricional, adequação proteica e possíveis riscos renais ou oncológicos. Responda em português, de forma clara e acolhedora.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": [\n        {\n          \"type\": \"text\",\n          \"text\": \"{{ $('node_parse_media').item.json.caption !== '' ? 'Legenda do paciente: ' + $('node_parse_media').item.json.caption : 'Analise este arquivo.' }}\"\n        },\n        {\n          \"type\": \"image_url\",\n          \"image_url\": {\n            \"url\": \"data:{{ $('node_parse_media').item.json.mimetype }};base64,{{ $binary.data.toString('base64') }}\",\n            \"detail\": \"high\"\n          }\n        }\n      ]\n    }\n  ],\n  \"max_tokens\": 1024\n}"
            }
          ]
        },
        "options": {}
      },
