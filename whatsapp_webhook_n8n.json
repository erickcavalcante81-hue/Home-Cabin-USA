    {
      "parameters": {
        "jsCode": "// Normaliza saída do Vision para o pipeline padrão\nconst visionResponse = $input.item.json.choices?.[0]?.message?.content ?? '';\nconst prev = $('node_parse_media').item.json;\n\nreturn [\n  {\n    json: {\n      from: prev.from,\n      pushName: prev.pushName,\n      timestamp: prev.timestamp,\n      messageType: 'text',\n      content: visionResponse,\n      originalType: prev.messageType,\n      caption: prev.caption\n    }\n  }\n];"
