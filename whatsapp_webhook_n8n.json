    {
      "parameters": {
        "jsCode": "// Normaliza a saída do Whisper para o formato padrão do pipeline\nconst transcription = $input.item.json.text ?? '';\nconst prev = $('node_parse_audio').item.json;\n\nreturn [\n  {\n    json: {\n      from: prev.from,\n      pushName: prev.pushName,\n      timestamp: prev.timestamp,\n      messageType: 'text',          // tratado como texto após transcrição\n      content: transcription,\n      originalType: 'audio',\n      durationSeconds: prev.durationSeconds\n    }\n  }\n];"
      },
