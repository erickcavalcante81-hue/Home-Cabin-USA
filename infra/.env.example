# ============================================================
# Variáveis de ambiente — Dr. João Holanda Infrastructure
# Copie para .env e preencha ANTES de rodar docker compose up
# ============================================================

# IP público da VPS (sem http://)
VPS_IP=

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=automacao
POSTGRES_PASSWORD=TROQUE_POR_SENHA_FORTE_32_CHARS
POSTGRES_DB=automacao

# Bancos individuais (criados via init-db.sql)
N8N_DB_NAME=n8n
EVOLUTION_DB_NAME=evolution

# ── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=TROQUE_POR_SENHA_FORTE_32_CHARS

# ── n8n ──────────────────────────────────────────────────────
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=TROQUE_POR_SENHA_FORTE
N8N_ENCRYPTION_KEY=GERE_COM_openssl_rand_hex_32

# ── Evolution API ────────────────────────────────────────────
EVOLUTION_API_KEY=GERE_COM_openssl_rand_hex_32
